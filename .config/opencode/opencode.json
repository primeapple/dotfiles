{
    "$schema": "https://opencode.ai/config.json",
    "model": "",
    "disabled_providers": ["anthropic", "openapi"],
    "provider": {
        "lmstudio": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "LM Studio (local)",
            "options": {
                "baseURL": "http://127.0.0.1:1234/v1"
            },
            "models": {
                "Edge-Quant/nanbeige4.1-3b": {
                    "name": "nanbeige4.1-3b"
                }
            }
        },
        "ollama": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "Ollama",
            "options": {
                "baseURL": "http://127.0.0.1:11434/v1"
            },
            "models": {
                "nanbeige:3b-16k": {
                    "name": "Nanbeige 3b (16k context)"
                }
            }
        }
    },
    "permission": {
        "bash": {
            "*": "ask",
            "./mvnw *": "allow",
            "cat *": "allow",
            "echo *": "allow",
            "find * -delete *": "ask",
            "find * -exec *": "ask",
            "find * -execdir *": "ask",
            "find * -ok *": "ask",
            "find * -okdir *": "ask",
            "find *": "allow",
            "gh issue list": "allow",
            "gh issue view *": "allow",
            "git diff *": "allow",
            "git log *": "allow",
            "git show *": "allow",
            "git status": "allow",
            "go test *": "allow",
            "gofmt *": "allow",
            "grep *": "allow",
            "head *": "allow",
            "ls *": "allow",
            "make *": "allow",
            "mkdir *": "allow",
            "mvn *": "allow",
            "mvnd *": "allow",
            "npm test *": "allow",
            "rg *": "allow",
            "sort *": "allow",
            "tail *": "allow",
            "wc *": "allow"
        },
        "edit": "allow",
        "external_directory": "ask",
        "webfetch": "ask"
    },
    "mcp": {
        "context7": {
            "type": "remote",
            "url": "https://mcp.context7.com/mcp",
            "headers": {
                "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
            }
        }
    }
}
